(load "../../carp-raymarch-renderer/renderer.carp")
(load "Test.carp")
(use Test)
(use Vector3)

(defn my-sdf [p]
  (- (Vector3.mag p) 1.0))

(defn my-id [p] 0)

(deftest integration-test
  (let [state (Test.State.init 0 0)
        config (Renderer.default-config)
        materials [(Material.make (Vector3.init 1.0 0.5 0.5) 0.5 0.0 0.0)]
        ray (Ray.make (Vector3.init 0.0 0.0 5.0) (Vector3.init 0.0 0.0 -1.0))
        color (Renderer.render-pixel &my-sdf &my-id &materials &ray &config)]
    (do
      (set! state (assert-true &state (> (Vector3.mag &color) 0.0) "Renderer produces colored pixels"))
      state)))
